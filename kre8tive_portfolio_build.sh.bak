#!/data/data/com.termux/files/usr/bin/bash
# ==========================================================
# KRE8TIVE.SPACE PORTFOLIO BUILDER (Cloudflare Pages via Git)
# - GoDaddy domains + GoDaddy sites (cards w/ thumbnails)
# - GitHub repos (from feed_database.json already in repo)
# - Vercel projects (via Vercel API)
# Output: index.html + vercel_projects.json
# Then: git commit + push (Cloudflare Pages auto-deploys)
# ==========================================================

set -euo pipefail

DOMAIN="${DOMAIN:-kre8tive.space}"
ORG="${ORG:-FacePrintPay}"

# Your Pages-connected repo is this repo (RepoDepot-Stargate)
REPO_DIR="$(pwd)"

# Pick your Vercel team (default = faceprintpays-projects)
VERCEL_TEAM_ID="${VERCEL_TEAM_ID:-team_o5UPga40oCf1HZghhny7eiDN}"

# Try to read Vercel token from common locations (you can also export VERCEL_TOKEN)
VERCEL_TOKEN="${VERCEL_TOKEN:-}"

need() { command -v "$1" >/dev/null 2>&1 || { echo "[x] missing: $1"; exit 1; }; }
need jq
need git
need gh
need curl

# ---------------------------
# GoDaddy portfolio lists
# ---------------------------
